{
  "name": "bare-module",
  "version": "7.0.0-0",
  "description": "The module system that powers Bare",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./protocol": {
      "types": "./lib/protocol.d.ts",
      "default": "./lib/protocol.js"
    },
    "./loader": {
      "types": "./lib/loader.d.ts",
      "default": "./lib/loader.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.c",
    "binding.js",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "brittle-bare --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-module.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-module/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-module#readme",
  "engines": {
    "bare": ">=1.31.0"
  },
  "dependencies": {
    "bare-bundle": "^1.3.0",
    "bare-module-lexer": "^1.6.1",
    "bare-module-resolve": "^1.12.3",
    "bare-module-traverse": "~2.4.2",
    "bare-path": "^3.0.0",
    "bare-type-stripper": "^0.1.2",
    "bare-url": "^2.0.1",
    "promaphore": "^1.0.0"
  },
  "devDependencies": {
    "bare-buffer": "^3.0.2",
    "brittle": "^3.1.1",
    "cmake-bare": "^1.1.6",
    "lunte": "^1.6.0",
    "prettier": "^3.3.3",
    "prettier-config-holepunch": "^2.0.0"
  },
  "peerDependencies": {
    "bare-buffer": "*"
  },
  "peerDependenciesMeta": {
    "bare-buffer": {
      "optional": true
    }
  }
}
